# =============================================================
# CONFIGURATION DU BOT — copiez ce fichier en ".env" et remplissez
# chaque valeur. Voir README.md pour le guide détaillé de chacune.
# =============================================================

# Le token de votre bot, obtenu via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=

# Votre identifiant Telegram personnel (seul vous pourrez piloter le bot)
OWNER_ID=

# L'identifiant de votre CANAL (là où les publications sont postées)
TELEGRAM_CHANNEL_ID=

# L'identifiant du GROUPE DE DISCUSSION lié au canal (là où les gens commentent)
TELEGRAM_GROUP_ID=

# (Optionnel) Clé API Anthropic pour les réponses intelligentes par IA
# Laissez vide si vous voulez seulement les règles par mots-clés
ANTHROPIC_API_KEY=

# Heure de publication quotidienne (format 24h, heure UTC)
POST_HOUR_UTC=9
POST_MINUTE_UTC=0
